# Google Drive OAuth 2.0 credentials for uploads
GOOGLE_DRIVE_ACCOUNT_COUNT=3
# Account 0 can also be used for regular uploads if poster/video folders are configured.
GOOGLE_DRIVE_SYSTEM_FOLDER_ID=your_backup_system_folder_id

# Account 0
GOOGLE_OAUTH_CLIENT_ID=your_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret
# Optional if you want to store the refresh token as an env var
GOOGLE_OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token
# Optional local file path to persist refresh token
GOOGLE_OAUTH_TOKEN_FILE=instance/google_drive_oauth.json

# Google Drive folder IDs for uploads
GOOGLE_DRIVE_POSTERS_FOLDER_ID=your_posters_folder_id
GOOGLE_DRIVE_VIDEOS_FOLDER_ID=your_videos_folder_id

# Account 1
GOOGLE_OAUTH_CLIENT_ID_1=your_client_id_1
GOOGLE_OAUTH_CLIENT_SECRET_1=your_client_secret_1
# Optional if you want to store the refresh token as an env var
GOOGLE_OAUTH_REFRESH_TOKEN_1=your_google_oauth_refresh_token_1
# Optional local file path to persist refresh token
GOOGLE_OAUTH_TOKEN_FILE_1=instance/google_drive_oauth_1.json

# Google Drive folder IDs for uploads
GOOGLE_DRIVE_POSTERS_FOLDER_ID_1=your_posters_folder_id_1
GOOGLE_DRIVE_VIDEOS_FOLDER_ID_1=your_videos_folder_id_1

# Account 2
GOOGLE_OAUTH_CLIENT_ID_2=your_client_id_2
GOOGLE_OAUTH_CLIENT_SECRET_2=your_client_secret_2
# Optional if you want to store the refresh token as an env var
GOOGLE_OAUTH_REFRESH_TOKEN_2=your_google_oauth_refresh_token_2
# Optional local file path to persist refresh token
GOOGLE_OAUTH_TOKEN_FILE_2=instance/google_drive_oauth_2.json

# Google Drive folder IDs for uploads
GOOGLE_DRIVE_POSTERS_FOLDER_ID_2=your_posters_folder_id_2
GOOGLE_DRIVE_VIDEOS_FOLDER_ID_2=your_videos_folder_id_2

# Account 3
GOOGLE_OAUTH_CLIENT_ID_3=your_client_id_3
GOOGLE_OAUTH_CLIENT_SECRET_3=your_client_secret_3
# Optional if you want to store the refresh token as an env var
GOOGLE_OAUTH_REFRESH_TOKEN_3=your_google_oauth_refresh_token_3
# Optional local file path to persist refresh token
GOOGLE_OAUTH_TOKEN_FILE_3=instance/google_drive_oauth_3.json

# Google Drive folder IDs for uploads
GOOGLE_DRIVE_POSTERS_FOLDER_ID_3=your_posters_folder_id_3
GOOGLE_DRIVE_VIDEOS_FOLDER_ID_3=your_videos_folder_id_3

# Flask settings
SECRET_KEY=replace-with-a-secret
SITE_NAME=Ani-BL
ADMIN_PASSWORD=admin_password=3,141592653589793
DATABASE_URL=sqlite:///instance/movie_manager.sqlite3
